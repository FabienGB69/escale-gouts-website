---
// Numéros et liens à mettre à jour avec les vraies infos de Feliada
const WHATSAPP_NUMBER = '33641086633'
const WHATSAPP_MSG    = encodeURIComponent('Bonjour, je souhaite un devis pour la gestion de mon logement.')
const EMAIL           = 'escaleetgouts@gmail.com'
const FACEBOOK_URL    = 'https://www.facebook.com/people/Escale-et-Go%C3%BBts/61574678044838/'
const INSTAGRAM_URL   = 'https://www.instagram.com/escaleetgouts'  // ← Mettre la vraie URL si elle existe
---

<!-- ═══════════════ BOUTONS FLOTTANTS DESKTOP (colonne droite) ═══════════════ -->
<div class="hidden md:flex flex-col gap-3 fixed right-5 bottom-8 z-50">

  <!-- WhatsApp -->
  <a
    href={`https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MSG}`}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Nous contacter sur WhatsApp"
    title="WhatsApp"
    class="group flex items-center gap-0 w-12 hover:w-44 overflow-hidden transition-all duration-300 bg-[#25D366] text-white rounded-full shadow-lg hover:shadow-xl h-12"
  >
    <span class="flex-shrink-0 w-12 h-12 flex items-center justify-center">
      <!-- WhatsApp SVG -->
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 fill-white" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </span>
    <span class="pr-4 whitespace-nowrap text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity duration-200">
      WhatsApp
    </span>
  </a>

  <!-- Email direct -->
  <a
    href={`mailto:${EMAIL}?subject=Demande de devis conciergerie&body=Bonjour,%0A%0AJe souhaite un devis pour la gestion de mon logement.%0A%0ACordialement`}
    aria-label="Envoyer un email"
    title="Email direct"
    class="group flex items-center gap-0 w-12 hover:w-44 overflow-hidden transition-all duration-300 bg-navy text-white rounded-full shadow-lg hover:shadow-xl h-12"
  >
    <span class="flex-shrink-0 w-12 h-12 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-none stroke-white stroke-2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22,6 12,13 2,6"/>
      </svg>
    </span>
    <span class="pr-4 whitespace-nowrap text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity duration-200">
      Email direct
    </span>
  </a>

  <!-- Facebook -->
  <a
    href={FACEBOOK_URL}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Facebook Escale et Goûts"
    title="Facebook"
    class="group flex items-center gap-0 w-12 hover:w-44 overflow-hidden transition-all duration-300 bg-[#1877F2] text-white rounded-full shadow-lg hover:shadow-xl h-12"
  >
    <span class="flex-shrink-0 w-12 h-12 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 fill-white" viewBox="0 0 24 24">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
    </span>
    <span class="pr-4 whitespace-nowrap text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity duration-200">
      Facebook
    </span>
  </a>

</div>

<!-- ═══════════════ BARRE MOBILE (bas d'écran) ═══════════════ -->
<div class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex border-t border-white/10 shadow-2xl">

  <!-- WhatsApp -->
  <a
    href={`https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MSG}`}
    target="_blank"
    rel="noopener noreferrer"
    class="flex-1 flex flex-col items-center justify-center gap-1 py-3 bg-[#25D366] text-white text-xs font-semibold active:opacity-80"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-white" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    WhatsApp
  </a>

  <!-- Email -->
  <a
    href={`mailto:${EMAIL}?subject=Demande de devis`}
    class="flex-1 flex flex-col items-center justify-center gap-1 py-3 bg-navy text-white text-xs font-semibold active:opacity-80"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-none stroke-white stroke-2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
      <polyline points="22,6 12,13 2,6"/>
    </svg>
    Email
  </a>

  <!-- Devis rapide -->
  <a
    href="/contact/"
    class="flex-1 flex flex-col items-center justify-center gap-1 py-3 bg-gold text-navy text-xs font-bold active:opacity-80"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
    </svg>
    Devis
  </a>

  <!-- Facebook -->
  <a
    href={FACEBOOK_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="flex-1 flex flex-col items-center justify-center gap-1 py-3 bg-[#1877F2] text-white text-xs font-semibold active:opacity-80"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-white" viewBox="0 0 24 24">
      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
    </svg>
    Facebook
  </a>

</div>

<!-- Spacer mobile pour que le contenu ne soit pas caché par la barre -->
<div class="md:hidden h-14"></div>
