---
// Formulaire → API /api/contact → Resend → escaleetgouts@gmail.com
---

<form
  id="contact-form"
  class="bg-white rounded-3xl shadow-lg p-8 md:p-10 space-y-5"
  novalidate
>
  <div class="grid md:grid-cols-2 gap-5">

    <div>
      <label class="block text-navy text-sm font-semibold mb-1.5" for="nom">
        Nom / Prénom *
      </label>
      <input
        id="nom" name="nom" type="text" required autocomplete="name"
        placeholder="Jean Dupont"
        class="w-full border border-navy/20 rounded-xl px-4 py-3 text-text focus:outline-none focus:border-gold transition-colors"
      />
    </div>

    <div>
      <label class="block text-navy text-sm font-semibold mb-1.5" for="email">
        Email *
      </label>
      <input
        id="email" name="email" type="email" required autocomplete="email"
        placeholder="jean@email.fr"
        class="w-full border border-navy/20 rounded-xl px-4 py-3 text-text focus:outline-none focus:border-gold transition-colors"
      />
    </div>

    <div>
      <label class="block text-navy text-sm font-semibold mb-1.5" for="telephone">
        Téléphone
      </label>
      <input
        id="telephone" name="telephone" type="tel" autocomplete="tel"
        placeholder="06 12 34 56 78"
        class="w-full border border-navy/20 rounded-xl px-4 py-3 text-text focus:outline-none focus:border-gold transition-colors"
      />
    </div>

    <div>
      <label class="block text-navy text-sm font-semibold mb-1.5" for="ville">
        Ville du logement *
      </label>
      <select
        id="ville" name="ville" required
        class="w-full border border-navy/20 rounded-xl px-4 py-3 text-text focus:outline-none focus:border-gold transition-colors"
      >
        <option value="">Sélectionnez une ville</option>
        <option value="Vienne (38)">Vienne (38)</option>
        <option value="Saint-Priest">Saint-Priest</option>
        <option value="Annonay (07)">Annonay (07)</option>
        <option value="Sud Lyon">Sud Lyon</option>
        <option value="Autre">Autre</option>
      </select>
    </div>

    <div>
      <label class="block text-navy text-sm font-semibold mb-1.5" for="nb-logements">
        Nombre de logements à gérer
      </label>
      <select
        id="nb-logements" name="nb_logements"
        class="w-full border border-navy/20 rounded-xl px-4 py-3 text-text focus:outline-none focus:border-gold transition-colors"
      >
        <option value="1">1 logement</option>
        <option value="2">2 logements</option>
        <option value="3+">3 logements ou plus</option>
      </select>
    </div>

    <div>
      <label class="block text-navy text-sm font-semibold mb-1.5" for="type-bien">
        Type de logement
      </label>
      <select
        id="type-bien" name="type_bien"
        class="w-full border border-navy/20 rounded-xl px-4 py-3 text-text focus:outline-none focus:border-gold transition-colors"
      >
        <option value="">Non précisé</option>
        <option value="Studio / T1">Studio / T1</option>
        <option value="T2">T2</option>
        <option value="T3">T3</option>
        <option value="T4+">T4 et plus</option>
        <option value="Maison">Maison</option>
      </select>
    </div>

  </div>

  <div>
    <label class="block text-navy text-sm font-semibold mb-1.5" for="message">
      Message (optionnel)
    </label>
    <textarea
      id="message" name="message" rows="4"
      placeholder="Décrivez votre logement, vos attentes, ou toute question particulière…"
      class="w-full border border-navy/20 rounded-xl px-4 py-3 text-text focus:outline-none focus:border-gold transition-colors resize-none"
    ></textarea>
  </div>

  <!-- Feedback -->
  <div id="form-success" class="hidden bg-green-50 border border-green-200 text-green-800 rounded-xl px-5 py-4 text-sm">
    ✅ Votre demande a bien été envoyée ! Feliada vous répondra dans les 24h.
  </div>
  <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-xl px-5 py-4 text-sm">
    ❌ Une erreur est survenue. Veuillez envoyer votre demande directement à escaleetgouts@gmail.com
  </div>

  <button
    type="submit"
    id="submit-btn"
    class="w-full bg-gold text-navy font-bold py-4 rounded-full hover:bg-gold-light transition-colors text-base disabled:opacity-60 disabled:cursor-not-allowed"
  >
    Envoyer ma demande de devis →
  </button>

  <p class="text-text/40 text-xs text-center">
    Sans engagement · Réponse sous 24h · {new Date().getFullYear()} © Escale et Goûts
  </p>
</form>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement
  const btn     = document.getElementById('submit-btn') as HTMLButtonElement
  const success = document.getElementById('form-success')!
  const error   = document.getElementById('form-error')!

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    btn.disabled = true
    btn.textContent = 'Envoi en cours…'
    success.classList.add('hidden')
    error.classList.add('hidden')

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      })

      if (res.ok) {
        success.classList.remove('hidden')
        form.reset()
      } else {
        error.classList.remove('hidden')
      }
    } catch {
      error.classList.remove('hidden')
    } finally {
      btn.disabled = false
      btn.textContent = 'Envoyer ma demande de devis →'
    }
  })
</script>
