---
const GOOGLE_URL = 'https://share.google/ifMou16euQZ0a2FSO'
const NOTE_GLOBALE = '4.8'
const NB_AVIS = '12'

const avis = [
  {
    nom: 'Patricia V.',
    note: 5,
    texte: 'Escale et Goûts gère mon appartement depuis plusieurs mois et je n\'ai absolument rien à faire. Les voyageurs laissent systématiquement de très bonnes notes et mes revenus ont augmenté de 30% par rapport à ma gestion en solo.',
    date: 'il y a 4 mois',
  },
  {
    nom: 'Marc D.',
    note: 5,
    texte: 'Le taux d\'occupation a franchement progressé et je ne reçois plus d\'appels de voyageurs à 23h. La commission de 22% est largement rentabilisée. Je recommande sans hésiter.',
    date: 'il y a 3 mois',
  },
  {
    nom: 'Sophie M.',
    note: 5,
    texte: 'J\'avais peur de perdre le contrôle sur mon bien mais Escale et Goûts m\'envoie un rapport chaque mois avec tous les détails. Le logement est toujours impeccable.',
    date: 'il y a 6 mois',
  },
  {
    nom: 'Thomas R.',
    note: 5,
    texte: 'Très réactifs, professionnels et à l\'écoute. Mon appartement est géré avec soin et les voyageurs sont ravis. Une vraie tranquillité d\'esprit pour moi.',
    date: 'il y a 2 mois',
  },
  {
    nom: 'Isabelle L.',
    note: 5,
    texte: 'Je recommande vivement Escale et Goûts ! Feliada est sérieuse, organisée et tient ses engagements. Mon logement n\'a jamais été aussi bien géré.',
    date: 'il y a 5 mois',
  },
]
---

<section class="bg-white py-16 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6 lg:px-10 mb-10">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">

      <!-- Titre + note globale -->
      <div class="flex items-center gap-5">
        <!-- Logo Google G -->
        <div class="w-12 h-12 rounded-full bg-white shadow-md border border-gray-100 flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-7 h-7">
            <path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/>
            <path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/>
            <path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/>
            <path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/>
          </svg>
        </div>

        <div>
          <p class="text-navy font-bold text-lg leading-none">Avis Google</p>
          <div class="flex items-center gap-1.5 mt-1">
            <span class="text-gold font-bold text-xl">{NOTE_GLOBALE}</span>
            <div class="flex gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 fill-gold" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <span class="text-text/45 text-sm">{NB_AVIS} avis</span>
          </div>
        </div>
      </div>

      <!-- CTA Google -->
      <a
        href={GOOGLE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border-2 border-navy/15 text-navy text-sm font-semibold px-5 py-2.5 rounded-full hover:border-gold hover:text-gold transition-colors self-start md:self-auto"
      >
        Laisser un avis
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>

    </div>
  </div>

  <!-- Bande de défilement infini -->
  <div class="relative">
    <!-- Dégradés masquants sur les côtés -->
    <div class="absolute left-0 top-0 h-full w-24 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 h-full w-24 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>

    <!-- Piste de défilement -->
    <div class="flex gap-5 avis-track" style="width: max-content;">
      <!-- Lot 1 -->
      {avis.map(a => (
        <a
          href={GOOGLE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-white border border-navy/8 rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow flex flex-col gap-3 no-underline"
          style="width: 300px; flex-shrink: 0;"
        >
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <div class="w-9 h-9 rounded-full bg-navy/10 flex items-center justify-center text-navy font-bold text-sm">
                {a.nom.charAt(0)}
              </div>
              <div>
                <p class="text-navy font-semibold text-sm leading-none">{a.nom}</p>
                <p class="text-text/40 text-xs mt-0.5">{a.date}</p>
              </div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-5 h-5 flex-shrink-0">
              <path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/>
              <path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/>
              <path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/>
              <path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/>
            </svg>
          </div>
          <!-- Étoiles -->
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(i => (
              <svg class={`w-3.5 h-3.5 ${i <= a.note ? 'fill-gold' : 'fill-gray-200'}`} viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <!-- Texte avis -->
          <p class="text-text/70 text-sm leading-relaxed line-clamp-3">{a.texte}</p>
        </a>
      ))}
      <!-- Lot 2 — doublon pour l'effet infini -->
      {avis.map(a => (
        <a
          href={GOOGLE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-white border border-navy/8 rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow flex flex-col gap-3 no-underline"
          style="width: 300px; flex-shrink: 0;"
        >
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <div class="w-9 h-9 rounded-full bg-navy/10 flex items-center justify-center text-navy font-bold text-sm">
                {a.nom.charAt(0)}
              </div>
              <div>
                <p class="text-navy font-semibold text-sm leading-none">{a.nom}</p>
                <p class="text-text/40 text-xs mt-0.5">{a.date}</p>
              </div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-5 h-5 flex-shrink-0">
              <path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/>
              <path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/>
              <path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/>
              <path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/>
            </svg>
          </div>
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(i => (
              <svg class={`w-3.5 h-3.5 ${i <= a.note ? 'fill-gold' : 'fill-gray-200'}`} viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-text/70 text-sm leading-relaxed line-clamp-3">{a.texte}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .avis-track {
    animation: scroll-avis 30s linear infinite;
  }
  .avis-track:hover {
    animation-play-state: paused;
  }
  @keyframes scroll-avis {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
