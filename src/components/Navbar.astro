---
const pathname = Astro.url.pathname

const liens = [
  { label: 'Services',    href: '/services-conciergerie/' },
  { label: 'Logements',   href: '/logements-geres/' },
  { label: 'Témoignages', href: '/temoignages/' },
  { label: 'À propos',    href: '/a-propos/' },
  { label: 'Blog',        href: '/blog/' },
]
---

<header class="fixed top-0 left-0 right-0 z-50 bg-cream/96 backdrop-blur-md border-b border-navy/8">
  <nav class="max-w-7xl mx-auto px-6 lg:px-10 h-16 flex items-center justify-between">

    <!-- Logo / Marque -->
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/images/logo-navbar.png"
        alt="Escale et Goûts Conciergerie"
        width="44" height="44"
        class="rounded-full object-cover group-hover:opacity-85 transition-opacity"
      />
      <span class="flex flex-col leading-none">
        <span class="font-serif text-navy text-lg font-semibold tracking-wide group-hover:text-coral transition-colors">
          Escale
        </span>
        <span class="font-sans text-gold text-[9px] font-semibold" style="letter-spacing:0.22em;text-transform:uppercase">
          Et Goûts · Conciergerie
        </span>
      </span>
    </a>

    <!-- Navigation desktop -->
    <ul class="hidden md:flex items-center gap-8">
      {liens.map(({ label, href }) => {
        const isActive = pathname === href
        return (
          <li>
            <a
              href={href}
              class:list={[
                'font-sans text-xs tracking-widest uppercase transition-colors relative pb-0.5',
                isActive
                  ? 'text-coral after:absolute after:bottom-0 after:left-0 after:right-0 after:h-px after:bg-coral'
                  : 'text-text/50 hover:text-navy',
              ]}
            >
              {label}
            </a>
          </li>
        )
      })}
    </ul>

    <!-- CTA desktop -->
    <div class="hidden md:flex items-center gap-4">
      <a
        href="/contact/"
        class="font-sans text-xs font-semibold tracking-widest uppercase bg-navy text-white px-6 py-3 hover:bg-coral transition-colors"
      >
        Devis gratuit
      </a>
    </div>

    <!-- Burger mobile -->
    <button
      id="burger"
      aria-label="Ouvrir le menu"
      class="md:hidden flex flex-col gap-1.5 p-2"
    >
      <span class="w-6 h-px bg-navy block"></span>
      <span class="w-4 h-px bg-navy block"></span>
      <span class="w-6 h-px bg-navy block"></span>
    </button>

  </nav>

  <!-- Menu mobile -->
  <div id="mobile-menu" class="hidden md:hidden bg-cream border-t border-navy/8">
    <div class="px-6 py-6 flex flex-col gap-5">
      {liens.map(({ label, href }) => (
        <a
          href={href}
          class="font-sans text-xs tracking-widest uppercase text-text/60 hover:text-coral transition-colors"
        >
          {label}
        </a>
      ))}
      <div class="pt-4 border-t border-navy/8">
        <a
          href="/contact/"
          class="block text-center font-sans text-xs font-semibold tracking-widest uppercase bg-navy text-white py-4 hover:bg-coral transition-colors"
        >
          Devis gratuit →
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer navbar fixe -->
<div class="h-16"></div>

<script>
  const burger = document.getElementById('burger')
  const menu   = document.getElementById('mobile-menu')
  burger?.addEventListener('click', () => menu?.classList.toggle('hidden'))
</script>
