---
interface Props {
  temoignage: {
    data: {
      nom:       string
      ville:     string
      note:      number
      type_bien?: string
      texte:     string
      date?:     string
    }
  }
}
const { temoignage } = Astro.props
const { nom, ville, note, type_bien, texte, date } = temoignage.data
const etoiles = '★'.repeat(note) + '☆'.repeat(5 - note)

// Formater la date : "2026-03-26" ou "2026-03" → "Publié le 26 mars 2026" / "mars 2026"
const MOIS = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre']
function formatDate(d: string): string {
  const parts = d.split('-')
  const annee = parts[0]
  const mois  = MOIS[parseInt(parts[1], 10) - 1] ?? ''
  if (parts[2]) {
    const jour = parseInt(parts[2], 10)
    return `Publié le ${jour} ${mois} ${annee}`
  }
  return `${mois.charAt(0).toUpperCase() + mois.slice(1)} ${annee}`
}
const dateLabel = date ? formatDate(date) : null
---

<blockquote class="bg-white rounded-2xl p-7 shadow-sm border border-navy/5 flex flex-col gap-4">
  <!-- Étoiles -->
  <div class="text-gold text-xl tracking-wide" aria-label={`Note : ${note}/5`}>
    {etoiles}
  </div>

  <!-- Texte -->
  <p class="text-text/80 text-base leading-relaxed italic">
    "{texte}"
  </p>

  <!-- Auteur -->
  <footer class="flex items-center gap-3 mt-2">
    <div class="w-10 h-10 rounded-full bg-navy/10 flex items-center justify-center text-navy font-bold text-sm flex-shrink-0">
      {nom.charAt(0).toUpperCase()}
    </div>
    <div>
      <p class="font-semibold text-navy text-sm">{nom}</p>
      <p class="text-text/50 text-xs">
        Propriétaire · {ville}{type_bien ? ` · ${type_bien}` : ''}
      </p>
      {dateLabel && (
        <p class="text-text/30 text-xs mt-0.5">{dateLabel}</p>
      )}
    </div>
  </footer>
</blockquote>
