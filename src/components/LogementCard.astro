---
interface Props {
  logement: {
    data: {
      titre:        string
      ville:        string
      accroche?:    string
      airbnb_url?:  string
      airbnb_id?:   string
      actif:        boolean
      [key: string]: unknown
    }
  }
}
const { logement } = Astro.props
const { titre, ville, accroche, airbnb_url, airbnb_id } = logement.data
---

<article class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow flex flex-col">

  <!-- Widget embed Airbnb -->
  {airbnb_id && (
    <div
      class="airbnb-embed-frame"
      data-id={airbnb_id}
      data-view="home"
      data-hide-price="true"
      style="width:100%; height:300px; display:block;"
    >
      <a href={airbnb_url} target="_blank" rel="noopener noreferrer">
        Voir sur Airbnb
      </a>
    </div>
    <script async src="https://www.airbnb.fr/embeddable/airbnb_jssdk"></script>
  )}

  <!-- Accroche + CTA -->
  <div class="p-6 flex flex-col flex-1">

    {accroche && (
      <p class="font-sans text-text/65 text-sm leading-relaxed mb-5">{accroche}</p>
    )}

    {airbnb_url && (
      <a
        href={airbnb_url}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-auto inline-flex items-center justify-center gap-2 bg-coral text-white font-sans font-semibold text-sm px-6 py-3 rounded-full hover:bg-coral/85 transition-colors"
      >
        Réserver ce logement →
      </a>
    )}

  </div>
</article>
