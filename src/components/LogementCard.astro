---
interface Props {
  logement: {
    data: {
      titre:        string
      ville:        string
      quartier?:    string
      capacite:     number
      superficie?:  number
      services:     string[]
      image:        string
      actif:        boolean
      airbnb_url?:  string
      airbnb_id?:   string
      booking_url?: string
    }
  }
}
const { logement } = Astro.props
const { titre, ville, quartier, capacite, superficie, services, image, airbnb_url, airbnb_id, booking_url } = logement.data
---

<article class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow group flex flex-col">
  <!-- Photo -->
  <div class="relative h-52 overflow-hidden bg-cream flex-shrink-0">
    <img
      src={image}
      alt={`Logement géré à ${ville} — ${titre}`}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      onerror="this.style.display='none'"
    />
    <div class="absolute top-3 left-3 flex gap-2">
      <span class="bg-navy text-white text-xs font-bold px-3 py-1 rounded-full">
        📍 {ville}
      </span>
    </div>
    <!-- Badge Airbnb si lien dispo -->
    {airbnb_url && (
      <div class="absolute top-3 right-3">
        <span class="bg-[#FF5A5F] text-white text-xs font-bold px-3 py-1 rounded-full">
          Airbnb ★
        </span>
      </div>
    )}
  </div>

  <!-- Contenu -->
  <div class="p-5 flex flex-col flex-1">
    <h3 class="font-serif text-navy text-xl mb-1">{titre}</h3>
    {quartier && <p class="text-text/50 text-sm mb-2">{quartier}</p>}

    <div class="flex items-center gap-4 text-sm text-text/60 mb-3">
      <span>👥 {capacite} voyageur{capacite > 1 ? 's' : ''}</span>
      {superficie && <span>📐 {superficie} m²</span>}
    </div>

    <!-- Services -->
    <ul class="flex flex-wrap gap-2 mb-4">
      {services.slice(0, 3).map(s => (
        <li class="bg-cream text-navy text-xs px-3 py-1 rounded-full border border-navy/10">
          {s}
        </li>
      ))}
      {services.length > 3 && (
        <li class="text-text/40 text-xs px-2 py-1">+{services.length - 3}</li>
      )}
    </ul>

    <!-- Widget embed Airbnb -->
    {airbnb_id && (
      <div class="mt-4 pt-4 border-t border-navy/5 -mx-5 px-5">
        <div
          class="airbnb-embed-frame rounded-xl overflow-hidden"
          data-id={airbnb_id}
          data-view="home"
          data-hide-price="true"
          style="width:100%; height:280px;"
        >
          <a href={airbnb_url} target="_blank" rel="noopener noreferrer">
            Voir sur Airbnb
          </a>
        </div>
        <script async src="https://www.airbnb.fr/embeddable/airbnb_jssdk"></script>
      </div>
    )}

  </div>
</article>
