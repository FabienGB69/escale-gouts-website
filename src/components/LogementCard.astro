---
interface Props {
  logement: {
    data: {
      titre:           string
      ville:           string
      capacite?:       number
      superficie?:     number
      chambres?:       number
      lits?:           number
      salles_de_bain?: number
      services?:       string[]
      accroche?:       string
      airbnb_url?:     string
      airbnb_id?:      string
      actif:           boolean
      [key: string]: unknown
    }
  }
}
const { logement } = Astro.props
const { titre, ville, capacite, superficie, chambres, lits, salles_de_bain, services, accroche, airbnb_url, airbnb_id } = logement.data

// Icônes équipements clés (les 4 premiers services)
const equipements = services?.slice(0, 4) ?? []
---

<article class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow flex flex-col">

  <!-- Widget embed Airbnb -->
  {airbnb_id && (
    <div
      class="airbnb-embed-frame"
      data-id={airbnb_id}
      data-view="home"
      data-hide-price="true"
      style="width:100%; height:300px; display:block;"
    >
      <a href={airbnb_url} target="_blank" rel="noopener noreferrer">
        Voir sur Airbnb
      </a>
    </div>
    <script async src="https://www.airbnb.fr/embeddable/airbnb_jssdk"></script>
  )}

  <!-- Infos + Accroche + CTA -->
  <div class="p-6 flex flex-col flex-1 gap-4">

    <!-- Infos capacité -->
    <div class="flex flex-wrap items-center gap-3 text-xs font-sans text-text/60 border-b border-navy/6 pb-4">
      {capacite && (
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-current opacity-60" viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
          {capacite} voyageur{capacite > 1 ? 's' : ''}
        </span>
      )}
      {chambres && (
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-current opacity-60" viewBox="0 0 24 24"><path d="M10 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0-6c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm9 9H5v-.75C5 12.56 7.69 11 10 11c.64 0 1.3.1 1.93.27C12.59 10.47 13.74 10 15 10c2.21 0 4 1.79 4 4v1zm-4-3c-.93 0-1.75.36-2.38.93.12.04.25.07.38.07 1.54 0 3 .54 4.08 1.5.57-.44.92-1.11.92-1.5 0-1.1-.9-1-2-1zm-5 4H3v-1C3 13.34 6.34 12 8 12c.16 0 .33.01.5.03C8.19 12.64 8 13.3 8 14v1z"/></svg>
          {chambres} chambre{chambres > 1 ? 's' : ''}
        </span>
      )}
      {lits && (
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-current opacity-60" viewBox="0 0 24 24"><path d="M7 13c1.66 0 3-1.34 3-3S8.66 7 7 7s-3 1.34-3 3 1.34 3 3 3zm12-6h-8v7H3V5H1v15h2v-3h18v3h2v-9c0-2.21-1.79-4-4-4z"/></svg>
          {lits} lit{lits > 1 ? 's' : ''}
        </span>
      )}
      {salles_de_bain && (
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-current opacity-60" viewBox="0 0 24 24"><path d="M7 6c0-.55.45-1 1-1s1 .45 1 1v1H7V6zm12 5H5V6c0-1.1-.9-2-2-2s-2 .9-2 2v5l1 8h18l1-8v-5h-2zm-1.27 9H6.27L5.28 13h13.44l-.99 7zM4 11V6c0-.28.22-.5.5-.5s.5.22.5.5v5H4zm16 0h-1V6c0-.28-.22-.5-.5-.5s-.5.22-.5.5v5h-1V6c0-1.1-.9-2-2-2H9V3H7v1H5.82C5.4 3.38 4.73 3 4 3c-1.1 0-2 .9-2 2v6H1v5l1 8h20l1-8v-5h-1z"/></svg>
          {salles_de_bain} salle{salles_de_bain > 1 ? 's' : ''} de bain
        </span>
      )}
      {superficie && (
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-current opacity-60" viewBox="0 0 24 24"><path d="M21 3H3C2 3 1 4 1 5v14c0 1 1 2 2 2h18c1 0 2-1 2-2V5c0-1-1-2-2-2zm0 16H3V5h18v14z"/></svg>
          {superficie} m²
        </span>
      )}
    </div>

    <!-- Équipements clés -->
    {equipements.length > 0 && (
      <ul class="flex flex-wrap gap-2">
        {equipements.map(e => (
          <li class="bg-cream text-navy text-xs px-3 py-1 rounded-full border border-navy/10 font-sans">
            {e}
          </li>
        ))}
        {(services?.length ?? 0) > 4 && (
          <li class="text-text/35 text-xs px-2 py-1 font-sans">+{(services?.length ?? 0) - 4}</li>
        )}
      </ul>
    )}

    <!-- Accroche -->
    {accroche && (
      <p class="font-sans text-text/60 text-sm leading-relaxed">{accroche}</p>
    )}

    <!-- CTA Réserver -->
    {airbnb_url && (
      <a
        href={airbnb_url}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-auto inline-flex items-center justify-center gap-2 bg-coral text-white font-sans font-semibold text-sm px-6 py-3 rounded-full hover:bg-coral/85 transition-colors"
      >
        Réserver ce logement →
      </a>
    )}

  </div>
</article>
